# Temporal Cloud
TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=your-temporal-api-key

# Firecrawl
FIRECRAWL_API_KEY=fc-...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Grok / xAI
GROK_API_KEY=xai-...

# Google – path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/home/ec2-user/es-msn-workflow/service-account.json

# Google Sheets – the spreadsheet ID from the sheet URL
GOOGLE_SHEET_ID=your-sheet-id
